# GreenThumb Cloud API — Environment Variables

# ---- Database ---------------------------------------------------------------
# Local dev: points to the db container
DATABASE_URL=postgresql+psycopg2://postgres:password@db:5432/greenthumb
# Production (AWS EC2): point to Supabase PostgreSQL
# DATABASE_URL=postgresql+psycopg2://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# ---- Supabase Storage (photo uploads — cloud handles this, NOT the Pi) ------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ---- Auth service (Java microservice) ---------------------------------------
AUTH_SERVICE_URL=http://auth-service:8081

# ---- Dev helpers ------------------------------------------------------------
# Set to "true" to skip JWT validation in local development.
# NEVER set this in production.
DEV_AUTH_BYPASS=false
