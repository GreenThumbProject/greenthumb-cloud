# GreenThumb Cloud — Docker Compose environment
# Copy to .env and fill in your Supabase project values.

# ---------------------------------------------------------------------------
# Supabase — PostgreSQL (SQLAlchemy / FastAPI)
# Use the transaction-mode pooler (port 6543) to avoid exhausting connections.
# Find this under: Supabase Dashboard → Project → Settings → Database → Connection string
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Supabase — JDBC (auth-service, account-service)
# ---------------------------------------------------------------------------
DB_URL=jdbc:postgresql://aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DB_USER=postgres.[project-ref]
DB_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Auth
# JWT_SECRET must match your Supabase project's JWT secret.
# Find it under: Supabase Dashboard → Project → Settings → API → JWT Secret
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-in-production

# Set to "true" only in local dev to skip JWT validation
DEV_AUTH_BYPASS=false

# ---------------------------------------------------------------------------
# Supabase Storage — used by sync routes to upload Pi photos
# SUPABASE_KEY should be the service-role key (not the anon key).
# ---------------------------------------------------------------------------
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=your-service-role-key
